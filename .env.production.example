# قالب بيئة الإنتاج على VPS — انسخه إلى .env واملأ القيم ثم: chmod 600 .env
# توليد قيم قوية:  openssl rand -hex 32
NODE_ENV=production

# الخادم يستمع على الحلقة المحلية فقط — nginx هو العميل الوحيد (لا تكشف 3000 للإنترنت).
HOST=127.0.0.1
PORT=3000

# القاعدة المركزية: منفذ 3307 مميّز (الخادم مشترك — لا نصادم خدمات أخرى)، على الحلقة المحلية فقط.
DB_CONTAINER=erp-mysql
DB_NAME=erp
DB_PORT=3307
DB_ROOT_PW=ضع-كلمة-قوية-هنا
DATABASE_URL=mysql://root:ضع-كلمة-قوية-هنا@127.0.0.1:3307/erp

# ذاكرة القاعدة: 2G ملائمة لخادم مشترك 16GB (ترتفع لاحقاً عند نمو البيانات).
DB_BUFFER_POOL=2G
# احتفاظ binlog ٣ أيام (استعادة نقطة-زمنية بين النسخ الليلية بلا التهام القرص).
DB_BINLOG_EXPIRE=259200
# مهلة انتظار قفل الصفوف ١٠ث — لا يتعلّق الكاشير خلف قفل طويل.
DB_LOCK_WAIT=10

# سرّ التوكنات — ٦٤ خانة hex على الأقل، لا تتركه افتراضياً أبداً.
JWT_SECRET=ضع-ناتج-openssl-rand-hex-32

# أول مدير (تُستعمل مرة واحدة عند البذرة seed:prod — كلمة قوية إلزامية).
ADMIN_EMAIL=admin@alroya.local
ADMIN_PASSWORD=ضع-كلمة-قوية-هنا

# أحادي الأصل خلف nginx ⇒ لا حاجة لـCORS (اتركه فارغاً).
ALLOWED_ORIGINS=

# النسخ الاحتياطي
BACKUP_DIR=backups
BACKUP_KEEP_DAILY=7
BACKUP_KEEP_WEEKLY=4
BACKUP_KEEP_MONTHLY=3
# تشفير النسخ للدفع الخارجي (gpg --symmetric AES256) — إلزامي على الـVPS.
# ⚠️ Escrow: احفظ هذه العبارة (مع DB_ROOT_PW وJWT_SECRET) في مكانين خارج الخادم على الأقل
# (مدير كلمات مرور المالك + ورقة في خزنة المتجر) — يوم يحترق الخادم، بدونها كل النسخ
# الخارجية حبرٌ على ورق. واختبر فكّ نسخة على جهاز المتجر بعد أول نسخة (دليل التعافي §٢).
BACKUP_GPG_PASSPHRASE=
# مجلد نسخ خارجي محلي (USB/قرص ثانٍ) — اختياري؛ السحب من جهاز المتجر هو الطبقة الخارجية الأساسية.
BACKUP_OFFSITE_DIR=

# المراقبة (اختياري): Sentry DSN للخادم
SENTRY_DSN_SERVER=

# ── تعدّد الشركات (اختياري، معطَّل افتراضياً) ─────────────────────────────
# اتركه فارغاً لبقاء هذا النشر أحادي الشركة كما هو اليوم (بلا أي تغيير سلوكي). لتفعيل عزل
# قاعدة بيانات فعلي لكل شركة على نفس خادم MySQL (شركات شقيقة): اضبط CONTROL_DATABASE_URL
# + INTEGRATIONS_ENCRYPTION_KEY (٦٤ خانة hex عبر openssl rand -hex 32)، ثم شغّل مرّة واحدة
# على الخادم: pnpm control:bootstrap && pnpm company:new <رمز> "<اسم>" --admin-email .. --admin-password ..
CONTROL_DATABASE_URL=
INTEGRATIONS_ENCRYPTION_KEY=
