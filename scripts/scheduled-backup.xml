<?xml version="1.0" encoding="UTF-16"?>
<!--
  مهمة نسخ احتياطي يومية لـMySQL — تُستورَد في Windows Task Scheduler.

  قبل الاستيراد: استبدل الموضعَين أدناه:
    1) <WorkingDirectory> و <Arguments>  ⇐  مسار تثبيت النظام الفعلي
    2) <UserId>                           ⇐  اسم مستخدم Windows الذي يملك Docker (أو احذف <Principal> لتشغيلها بـSYSTEM)

  الاستيراد (PowerShell كمسؤول):
    schtasks /Create /TN "AlRoya ERP - Daily Backup" /XML "scripts\scheduled-backup.xml"

  للحارس (إعادة تشغيل الحاوية إن سقطت) أنشئ مهمة ساعية يدوياً:
    schtasks /Create /SC HOURLY /TN "AlRoya ERP - Docker Watchdog" ^
      /TR "node -r dotenv/config scripts\docker-watchdog.mjs" /ST 00:00

  راجع docs/redeploy.md للتفصيل.
-->
<Task version="1.2" xmlns="http://schemas.microsoft.com/windows/2004/02/mit/task">
  <RegistrationInfo>
    <Description>نسخة احتياطية يومية لقاعدة بيانات الرؤية العربية (mysqldump + تدوير + نسخة خارجية)</Description>
    <URI>\AlRoya ERP - Daily Backup</URI>
  </RegistrationInfo>
  <Triggers>
    <CalendarTrigger>
      <StartBoundary>2026-01-01T02:00:00</StartBoundary>
      <Enabled>true</Enabled>
      <ScheduleByDay>
        <DaysInterval>1</DaysInterval>
      </ScheduleByDay>
    </CalendarTrigger>
  </Triggers>
  <Principals>
    <Principal id="Author">
      <!-- استبدل DOMAIN\User أو احذف هذا القسم لتشغيلها بـSYSTEM -->
      <UserId>DOMAIN\User</UserId>
      <LogonType>InteractiveToken</LogonType>
      <RunLevel>LeastPrivilege</RunLevel>
    </Principal>
  </Principals>
  <Settings>
    <MultipleInstancesPolicy>IgnoreNew</MultipleInstancesPolicy>
    <DisallowStartIfOnBatteries>false</DisallowStartIfOnBatteries>
    <StopIfGoingOnBatteries>false</StopIfGoingOnBatteries>
    <AllowHardTerminate>true</AllowHardTerminate>
    <StartWhenAvailable>true</StartWhenAvailable>
    <RunOnlyIfNetworkAvailable>false</RunOnlyIfNetworkAvailable>
    <ExecutionTimeLimit>PT30M</ExecutionTimeLimit>
    <Enabled>true</Enabled>
    <Hidden>false</Hidden>
    <WakeToRun>false</WakeToRun>
    <Priority>7</Priority>
    <RestartOnFailure>
      <Interval>PT15M</Interval>
      <Count>3</Count>
    </RestartOnFailure>
  </Settings>
  <Actions Context="Author">
    <Exec>
      <Command>node</Command>
      <!-- -r dotenv/config يحمّل .env قبل تشغيل السكربت -->
      <Arguments>-r dotenv/config scripts\backup.mjs</Arguments>
      <WorkingDirectory>C:\path\to\business_management_system</WorkingDirectory>
    </Exec>
  </Actions>
</Task>
