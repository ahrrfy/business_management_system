# ───────────────────────────────────────────────────────────────────────────
# قالب متغيّرات البيئة لنظام الرؤية العربية.
# انسخه إلى .env واملأ القيم:  copy .env.example .env   (Windows)
# ⚠ ملف .env الحقيقي مُستثنى من git — لا تضع أسراراً هنا، فقط أمثلة.
# ───────────────────────────────────────────────────────────────────────────

# البيئة: development | production
NODE_ENV=production

# منفذ خادم التطبيق
PORT=3000

# ── قاعدة البيانات (MySQL 8) ──────────────────────────────────────────────
# صيغة: mysql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=mysql://root:CHANGE_ME@127.0.0.1:3306/erp

# قاعدة الاختبارات (vitest) — منفصلة عن الإنتاج
TEST_DATABASE_URL=mysql://root:CHANGE_ME@127.0.0.1:3306/erp_test

# ── سرّ توقيع الجلسات (JWT) ───────────────────────────────────────────────
# ولّد سرّاً قويّاً (٦٤ خانة): node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_ME_64_HEX_CHARS

# ── مستخدم admin الأوّل (يُنشأ بأمر seed) ─────────────────────────────────
ADMIN_EMAIL=admin@alroya.local
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── النسخ الاحتياطي (scripts/backup.mjs + backup-rotate.mjs) ───────────────
# حاوية Docker لقاعدة البيانات وبيانات الاتصال للـmysqldump
DB_CONTAINER=erp-mysql
DB_NAME=erp
DB_ROOT_PW=CHANGE_ME
DB_PORT=3306

# مجلّد حفظ النسخ المحلّية (افتراضي backups/ المُستثنى من git)
BACKUP_DIR=backups

# سياسة الاحتفاظ (عدد النسخ المُبقاة في كل فئة)
BACKUP_KEEP_DAILY=7
BACKUP_KEEP_WEEKLY=4
BACKUP_KEEP_MONTHLY=3

# مجلّد النسخ الخارجي (OneDrive/USB) — اتركه فارغاً لتعطيله
# مثال Windows: BACKUP_OFFSITE_DIR=C:\Users\me\OneDrive\erp-backups
BACKUP_OFFSITE_DIR=

# مجلّد السجلّات (حارس Docker)
LOG_DIR=logs

# ── الاعتمادية والتسجيل والحماية (shared/errorMap + server/index + sentry) ──
# مستوى التسجيل: trace|debug|info|warn|error (افتراضي debug في dev، info في الإنتاج)
LOG_LEVEL=info

# مراقبة الأخطاء عبر Sentry — اتركها فارغة لتعطيلها (لا أثر إطلاقاً)
SENTRY_DSN_SERVER=
# DSN العميل يجب أن يبدأ بـVITE_ ليصل للمتصفّح (تحميل ديناميكي ⇒ ٠ أثر على الحزمة)
VITE_SENTRY_DSN_CLIENT=
SENTRY_TRACES_RATE=0

# أصول CORS المسموحة (مفصولة بفواصل) — اتركها فارغة للتشغيل أحادي الأصل
ALLOWED_ORIGINS=

# حدود معدّل الطلبات (لكل ١٥ دقيقة)
RATE_LIMIT_MAX=1000
LOGIN_RATE_LIMIT_MAX=10

# حجم تجمّع اتصالات قاعدة البيانات
DB_POOL_LIMIT=20

# ── تعدّد الشركات (server/tenancy/) — اختياري، معطَّل افتراضياً ─────────────
# اتركه فارغاً/محذوفاً للنشر العادي أحادي الشركة (لا أثر إطلاقاً). لتفعيل عزل قاعدة بيانات
# فعلي لكل شركة (شركات شقيقة/بيع النظام كمنتج): اضبط CONTROL_DATABASE_URL (قاعدة تحكّم
# منفصلة تماماً عن DATABASE_URL، تحوي جدول الشركات وحسابات مدراء المنصّة)، شغّل
# `pnpm control:bootstrap` مرّة واحدة، ثم `pnpm company:new <رمز> "<اسم>" --admin-email .. --admin-password ..`
# لكل شركة (يُنشئ قاعدتها + مستخدم MySQL مخصّص أقلّ امتيازاً تلقائياً)، و`pnpm platform-admin:new`
# لحساب تشغيلي يدير الشركات عبر /platform-admin. التفصيل: ذاكرة multi-company-tenancy.
CONTROL_DATABASE_URL=

# مفتاح تشفير بيانات اتصال قاعدة كل شركة داخل قاعدة التحكّم (AES-256-GCM) — **إلزامي** إن
# ضبطتَ CONTROL_DATABASE_URL أعلاه (وإلا فشل فكّ بيانات اتصال الشركات). نفسه يُستعمل أيضاً
# لتشفير tokens التكاملات (WhatsApp/Instagram) — إن كنت تستعمل تلك الميزة فهو مُهيَّأ مسبقاً.
# ولّده بنفس طريقة JWT_SECRET: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTEGRATIONS_ENCRYPTION_KEY=

# ── إشعارات Web Push (Morning Brief) — server/services/pushService.ts ──────
# اتركها فارغة لتعطيل الميزة كليّاً (بلا أثر). لتفعيلها:
#  ١) ولّد زوج مفاتيح VAPID مرّة واحدة:
#     node -e "const w=require('web-push');const k=w.generateVAPIDKeys();console.log('PUB='+k.publicKey+'\nPRV='+k.privateKey);"
#  ٢) ضع العام في VAPID_PUBLIC_KEY والخاص في VAPID_PRIVATE_KEY.
#  ٣) VAPID_SUBJECT بريد مسؤول (متصفّح Chrome يشترطه — الافتراضي admin@alroya.local يعمل).
# المفتاح الخاص سرّ مطلق — تسريبه يُتيح إرسال إشعارات مزوَّرة باسم الخادم.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@alroya.local
# جدولة الإشعار الصباحي (cron خماسي، توقيت UTC). الافتراضي 04:00 UTC = 07:00 بغداد.
MORNING_PUSH_CRON=0 4 * * *

# ── جسر الطباعة الصامتة (server/services/printService.ts) ──────────────────
# وجهة الطباعة المباشرة لفواتير الكاشير دون حوار المتصفّح. اتركها فارغة لتعطيل الجسر
# (يتراجع العميل تلقائياً لـWebUSB ثم لحوار المتصفّح). الصيغ المدعومة:
#   tcp://<ip>[:<port>]   طابعة حرارية شبكية RAW (المنفذ الافتراضي 9100) — الأوثق، بلا تعريفات. (موصى به)
#   share://<ShareName>   طابعة Windows مشتركة بنوع RAW (شارِك طابعتك USB باسم ثم استعمله هنا)
# أمثلة:
#   PRINT_TARGET=tcp://192.168.1.50:9100
#   PRINT_TARGET=share://POS80
PRINT_TARGET=
